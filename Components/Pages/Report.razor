@page "/report"
@rendermode InteractiveServer
@using GreenFactory.Services
@using GreenFactory.Models
@using Microsoft.EntityFrameworkCore @* 👈 เพิ่มการเรียกใช้ EF Core *@
@inject EnergyService EnergyService
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>รายงาน - Green Factory</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">รายงาน</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
    ประวัติการใช้พลังงานและ Carbon ย้อนหลัง 7 วัน
</MudText>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">⚡ Trend พลังงาน (kWh) รายวัน</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@energySeries"
                              ChartOptions="@chartOptions"
                              Width="100%" Height="250px" />
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">☁️ Trend Carbon (kgCO₂e) รายวัน</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@carbonSeries"
                              ChartOptions="@chartOptions"
                              Width="100%" Height="250px" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">📋 ประวัติการบันทึกข้อมูล</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton StartIcon="@Icons.Material.Filled.Download"
                           Variant="Variant.Outlined" Color="Color.Primary"
                           Size="Size.Small" OnClick="ExportCsv">
                    Export CSV
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <MudTable Items="records" Hover="true" Striped="true" Dense="true"
                      SortLabel="Sort By" AllowUnsorted="false">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<EnergyRecord, object>(x => x.Timestamp)">วันที่/เวลา</MudTableSortLabel></MudTh>
                    <MudTh>Line</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EnergyRecord, object>(x => x.kWh)">kWh</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EnergyRecord, object>(x => x.WaterM3)">น้ำ (ลบ.ม.)</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EnergyRecord, object>(x => x.CarbonKgCO2e)">Carbon (kgCO₂e)</MudTableSortLabel></MudTh>
                    <MudTh>จัดการ</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Timestamp.ToString("dd/MM/yyyy HH:mm")</MudTd>
                    <MudTd><MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.MeterName</MudChip></MudTd>
                    <MudTd>@context.kWh.ToString("N2")</MudTd>
                    <MudTd>@context.WaterM3.ToString("N2")</MudTd>
                    <MudTd>@context.CarbonKgCO2e.ToString("N2")</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary" Size="Size.Small"
                                       OnClick="() => OpenEdit(context)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error" Size="Size.Small"
                                       OnClick="() => OpenDelete(context)" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                </PagerContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
}

<MudDialog @bind-Visible="showEdit">
    <TitleContent>✏️ แก้ไขข้อมูล</TitleContent>
    <DialogContent>
        @if (editModel != null)
        {
            <MudSelect T="string" Label="Line" @bind-Value="editModel.MeterName"
                       Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="@("Line A")" />
                <MudSelectItem Value="@("Line B")" />
                <MudSelectItem Value="@("Line C")" />
            </MudSelect>
            <MudNumericField T="double" Label="พลังงาน (kWh)" @bind-Value="editModel.kWh"
                             @bind-Value:after="RecalcEdit"
                             Variant="Variant.Outlined" Class="mb-3" Min="0" />
            <MudNumericField T="double" Label="น้ำ (ลบ.ม.)" @bind-Value="editModel.WaterM3"
                             @bind-Value:after="RecalcEdit"
                             Variant="Variant.Outlined" Class="mb-3" Min="0" />
            <MudAlert Severity="Severity.Info">
                Carbon: <b>@editCarbon.ToString("F2") kgCO₂e</b>
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => showEdit = false">ยกเลิก</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveEdit">บันทึก</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="showDelete">
    <TitleContent>🗑️ ยืนยันการลบ</TitleContent>
    <DialogContent>
        <MudText>ต้องการลบข้อมูล <b>@deleteTarget?.MeterName</b> วันที่ <b>@deleteTarget?.Timestamp.ToString("dd/MM/yyyy HH:mm")</b> ใช่ไหม?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => showDelete = false">ยกเลิก</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ConfirmDelete">ลบ</MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ✅ เปลี่ยนจาก const เป็นตัวแปรธรรมดา และกำหนดค่าเริ่มต้นสำรองไว้
    private double emissionElec = 0.4999;
    private double emissionWater = 0.7080;

    private bool isLoading = true;
    private List<EnergyRecord> records = new();
    private List<ChartSeries<double>> energySeries = new();
    private List<ChartSeries<double>> carbonSeries = new();
    private ChartOptions chartOptions = new();

    private bool showEdit;
    private EnergyRecord? editModel;
    private double editCarbon;

    private bool showDelete;
    private EnergyRecord? deleteTarget;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        records = await EnergyService.GetRecentRecordsAsync(50);

        // 🔍 ดึงค่า Factor มาจากตาราง AppSettings ในฐานข้อมูลแบบ Real-time
        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            var elecSetting = await db.AppSettings.FirstOrDefaultAsync(s => s.Key == "EmissionElec");
            var waterSetting = await db.AppSettings.FirstOrDefaultAsync(s => s.Key == "EmissionWater");

            if (elecSetting != null) emissionElec = elecSetting.Value;
            if (waterSetting != null) emissionWater = waterSetting.Value;
        }

        var last7Days = Enumerable.Range(0, 7)
            .Select(i => DateTime.Today.AddDays(-6 + i)).ToList();
        chartOptions = new ChartOptions();

        var allRecords = await EnergyService.GetRecentRecordsAsync(500);

        energySeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "พลังงาน (kWh)",
                Data = last7Days.Select(day =>
                    allRecords.Where(r => r.Timestamp.Date == day.Date).Sum(r => r.kWh)
                ).ToArray()
            }
        };

        carbonSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "Carbon (kgCO₂e)",
                Data = last7Days.Select(day =>
                    allRecords.Where(r => r.Timestamp.Date == day.Date).Sum(r => r.CarbonKgCO2e)
                ).ToArray()
            }
        };
        isLoading = false;
    }

    private void OpenEdit(EnergyRecord r)
    {
        editModel = new EnergyRecord
        {
            Id = r.Id, MeterName = r.MeterName,
            Timestamp = r.Timestamp,
            kWh = r.kWh, WaterM3 = r.WaterM3,
            CarbonKgCO2e = r.CarbonKgCO2e
        };
        RecalcEdit();
        showEdit = true;
    }

    private void RecalcEdit()
    {
        if (editModel == null) return;
        // ✅ เปลี่ยนมาคำนวณตามตัวแปรที่ดึงมาจากฐานข้อมูลแล้ว
        editCarbon = (editModel.kWh * emissionElec) + (editModel.WaterM3 * emissionWater);
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;
        editModel.CarbonKgCO2e = Math.Round(editCarbon, 2);

        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.EnergyRecords.FindAsync(editModel.Id);
        if (existing != null)
        {
            existing.MeterName     = editModel.MeterName;
            existing.kWh           = Math.Round(editModel.kWh, 2);
            existing.WaterM3       = Math.Round(editModel.WaterM3, 2);
            existing.CarbonKgCO2e  = editModel.CarbonKgCO2e;
            await db.SaveChangesAsync();
        }

        showEdit = false;
        await LoadData();
    }

    private void OpenDelete(EnergyRecord r)
    {
        deleteTarget = r;
        showDelete = true;
    }

    private async Task ConfirmDelete()
    {
        if (deleteTarget == null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.EnergyRecords.FindAsync(deleteTarget.Id);
        if (existing != null)
        {
            db.EnergyRecords.Remove(existing);
            await db.SaveChangesAsync();
        }

        showDelete = false;
        await LoadData();
    }

    private async Task ExportCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("วันที่/เวลา,Line,kWh,น้ำ (ลบ.ม.),Carbon (kgCO2e)");

        foreach (var r in records)
        {
            sb.AppendLine($"{r.Timestamp:dd/MM/yyyy HH:mm},{r.MeterName},{r.kWh:N2},{r.WaterM3:N2},{r.CarbonKgCO2e:N2}");
        }

        var bytes = System.Text.Encoding.UTF8.GetPreamble()
            .Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString()))
            .ToArray();
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"GreenFactory_{DateTime.Today:yyyyMMdd}.csv";

        await JS.InvokeVoidAsync("downloadFile", base64, fileName);
    }
}